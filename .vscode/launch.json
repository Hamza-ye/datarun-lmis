{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI (backend)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "jinja": true
        }
    ]
}